// NyxAegis CRM - Hospital Business Development Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// WHITE-LABEL ORGANIZATION
// ─────────────────────────────────────────

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#00d4ff")
  accentColor     String   @default("#fbbf24")
  customDomain    String?  @unique
  supportEmail    String?
  stripeAccountId String?
  planTier        String   @default("starter")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users User[]

  @@map("organizations")
}

// ─────────────────────────────────────────
// AUTH / USERS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  REP
  ACCOUNT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(ACCOUNT)
  preferences   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts  Account[]
  sessions  Session[]

  rep       Rep?
  hospital  Hospital?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// BD REPS (replaces Pilots)
// ─────────────────────────────────────────

enum RepStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
  SUSPENDED
}

model Rep {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone        String?
  city         String?
  state        String?
  zip          String?
  bio          String?
  title        String?
  territory    String?

  // Healthcare credentials
  hipaaTrainedAt   DateTime?
  hipaaDocUrl      String?
  licensedStates   String[]

  // Business info
  businessName  String?
  w9OnFile      Boolean  @default(false)
  w9DocUrl      String?

  // Operational
  status  RepStatus @default(PENDING_REVIEW)
  rating  Float?
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  territories    RepTerritory[]
  opportunities  Opportunity[]
  complianceDocs ComplianceDoc[]
  payments       RepPayment[]
  contracts      Contract[]
  activities     Activity[]
  reviews        RepReview[]
  availability   RepAvailability[]
  w9Form         W9Form?
  leads          Lead[]

  @@map("reps")
}

model RepTerritory {
  id      String @id @default(cuid())
  repId   String
  rep     Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)
  state   String
  city    String?
  region  String?
  notes   String?
  createdAt DateTime @default(now())

  @@map("rep_territories")
}

model RepAvailability {
  id        String   @id @default(cuid())
  repId     String
  rep       Rep      @relation(fields: [repId], references: [id], onDelete: Cascade)
  date      DateTime
  available Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  @@map("rep_availability")
}

model RepReview {
  id        String   @id @default(cuid())
  repId     String
  rep       Rep      @relation(fields: [repId], references: [id], onDelete: Cascade)
  rating    Float
  comment   String?
  reviewedBy String?
  createdAt DateTime @default(now())

  @@map("rep_reviews")
}

// ─────────────────────────────────────────
// HOSPITALS (Account portal users - replaces Clients)
// ─────────────────────────────────────────

enum HospitalStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CHURNED
}

enum HospitalType {
  ACUTE_CARE
  CRITICAL_ACCESS
  SPECIALTY
  HEALTH_SYSTEM
  AMBULATORY
  LONG_TERM_CARE
  BEHAVIORAL_HEALTH
  REHABILITATION
  CHILDRENS
  CANCER_CENTER
  OTHER
}

model Hospital {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  hospitalName   String
  systemName     String?
  hospitalType   HospitalType @default(ACUTE_CARE)
  npi            String?
  taxId          String?

  // Size & capabilities
  bedCount       Int?
  annualRevenue  Decimal?
  serviceLines   String[]

  // Primary contact
  primaryContactName  String?
  primaryContactTitle String?
  primaryContactEmail String?
  primaryContactPhone String?

  // Address
  address String?
  city    String?
  state   String?
  zip     String?

  // BD relationship
  status         HospitalStatus @default(PROSPECT)
  assignedRepId  String?
  contractValue  Decimal?
  notes          String?
  source         String?

  // Portal credentials
  portalPassword String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts      Contact[]
  opportunities Opportunity[]
  invoices      Invoice[]
  contracts     Contract[]
  activities    Activity[]
  leads         Lead[]

  @@map("hospitals")
}

// ─────────────────────────────────────────
// CONTACTS (Hospital decision makers)
// ─────────────────────────────────────────

enum ContactType {
  CMO
  CFO
  CNO
  CEO
  COO
  DEPARTMENT_HEAD
  PHYSICIAN_CHAMPION
  VP_BUSINESS_DEVELOPMENT
  DIRECTOR
  COORDINATOR
  OTHER
}

model Contact {
  id         String @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  name       String
  title      String?
  type       ContactType @default(OTHER)
  email      String?
  phone      String?
  department String?
  isPrimary  Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@map("contacts")
}

// ─────────────────────────────────────────
// LEADS (Pre-hospital prospects)
// ─────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  UNQUALIFIED
}

enum LeadSource {
  REFERRAL
  COLD_OUTREACH
  CONFERENCE
  INBOUND
  LINKEDIN
  WEBINAR
  EXISTING_RELATIONSHIP
  OTHER
}

model Lead {
  id           String @id @default(cuid())
  hospitalName String
  systemName   String?
  hospitalType HospitalType?
  bedCount     Int?
  state        String?
  city         String?

  contactName  String?
  contactEmail String?
  contactPhone String?
  contactTitle String?

  serviceInterest String?
  estimatedValue  Decimal?
  notes           String?

  status  LeadStatus @default(NEW)
  source  LeadSource @default(OTHER)
  priority String    @default("MEDIUM")

  assignedRepId String?
  assignedRep   Rep?   @relation(fields: [assignedRepId], references: [id])

  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@map("leads")
}

// ─────────────────────────────────────────
// OPPORTUNITIES (replaces Jobs)
// ─────────────────────────────────────────

enum OpportunityStage {
  DISCOVERY
  QUALIFICATION
  DEMO
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
  ON_HOLD
}

enum ServiceLine {
  CARDIOLOGY
  ONCOLOGY
  ORTHOPEDICS
  NEUROLOGY
  WOMENS_HEALTH
  PEDIATRICS
  BEHAVIORAL_HEALTH
  PRIMARY_CARE
  SURGICAL_SERVICES
  EMERGENCY_MEDICINE
  RADIOLOGY
  LABORATORY
  PHARMACY
  REHABILITATION
  HOME_HEALTH
  TELEHEALTH
  REVENUE_CYCLE
  SUPPLY_CHAIN
  IT_SOLUTIONS
  STAFFING
  OTHER
}

model Opportunity {
  id          String @id @default(cuid())
  title       String
  description String?

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  assignedRepId String?
  assignedRep   Rep?    @relation(fields: [assignedRepId], references: [id])

  stage       OpportunityStage @default(DISCOVERY)
  serviceLine ServiceLine      @default(OTHER)
  value       Decimal?
  closeDate   DateTime?
  priority    String   @default("MEDIUM")

  notes       String?
  lostReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]
  invoices   Invoice[]
  contracts  Contract[]

  @@map("opportunities")
}

// ─────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id          String @id @default(cuid())
  invoiceNumber String @unique
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  status      InvoiceStatus @default(DRAFT)
  totalAmount Decimal
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  lineItems   Json?

  stripePaymentIntentId String?
  stripeInvoiceId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// ─────────────────────────────────────────
// CONTRACTS
// ─────────────────────────────────────────

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id         String @id @default(cuid())
  title      String
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  assignedRepId String?
  assignedRep   Rep?    @relation(fields: [assignedRepId], references: [id])

  status     ContractStatus @default(DRAFT)
  startDate  DateTime?
  endDate    DateTime?
  value      Decimal?
  terms      String?
  fileUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contracts")
}

// ─────────────────────────────────────────
// COMPLIANCE DOCUMENTS
// ─────────────────────────────────────────

enum ComplianceDocType {
  HIPAA_TRAINING
  STATE_LICENSE
  NDA
  BAA
  MSA
  W9
  INSURANCE
  BACKGROUND_CHECK
  OTHER
}

model ComplianceDoc {
  id      String @id @default(cuid())
  repId   String
  rep     Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  type       ComplianceDocType
  title      String
  fileUrl    String?
  expiresAt  DateTime?
  verified   Boolean @default(false)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compliance_docs")
}

// ─────────────────────────────────────────
// ACTIVITIES (CRM activity log)
// ─────────────────────────────────────────

enum ActivityType {
  CALL
  EMAIL
  NOTE
  MEETING
  TASK
  PROPOSAL_SENT
  CONTRACT_SENT
  DEMO_COMPLETED
  SITE_VISIT
  CONFERENCE
  FOLLOW_UP
}

model Activity {
  id    String @id @default(cuid())
  type  ActivityType
  title String
  notes String?

  repId String?
  rep   Rep?   @relation(fields: [repId], references: [id])

  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  leadId String?
  lead   Lead?  @relation(fields: [leadId], references: [id])

  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  scheduledAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("activities")
}

// ─────────────────────────────────────────
// REP PAYMENTS
// ─────────────────────────────────────────

enum RepPaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

model RepPayment {
  id     String @id @default(cuid())
  repId  String
  rep    Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  amount      Decimal
  description String?
  status      RepPaymentStatus @default(PENDING)
  paidAt      DateTime?
  periodStart DateTime?
  periodEnd   DateTime?

  stripeTransferId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rep_payments")
}

// ─────────────────────────────────────────
// W-9 FORMS
// ─────────────────────────────────────────

model W9Form {
  id     String @id @default(cuid())
  repId  String @unique
  rep    Rep    @relation(fields: [repId], references: [id], onDelete: Cascade)

  legalName     String
  businessName  String?
  taxClassification String?
  ein           String?
  ssn           String?
  address       String?
  city          String?
  state         String?
  zip           String?
  signedAt      DateTime?
  fileUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("w9_forms")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String  @id @default(cuid())
  userId    String
  title     String
  body      String?
  type      String  @default("INFO")
  read      Boolean @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────
// MESSAGES / CHAT
// ─────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@map("messages")
}
